# ── MosendPay environment ──────────────────────────────────────────────────────
# Copy to .env and adjust. Everything has a safe local default.

NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TTL=15m

# Platform fee in basis points (195 = 1.95%)
DEFAULT_FEE_BPS=195

# Database
# Leave DATABASE_URL unset to use local SQLite (zero infra).
# DATABASE_URL=postgres://user:pass@localhost:5432/mosendpay
SQLITE_PATH=./mosendpay.db

# PSP provider: mock | hubtel | paystack | flutterwave
PSP_PROVIDER=mock
MOCK_CALLBACK_DELAY_MS=1500
